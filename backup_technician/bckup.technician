<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Technician Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="script.js" defer></script>
</head>

<body class="bg-gray-100">
  <div class="flex">
    <!-- Sidebar -->
    <aside class="w-64 bg-gray-800 text-white h-screen p-4">
      <h2 class="text-2xl font-bold mb-6">TurnFlow™</h2>
      <ul>
        <li class="mb-3"><a href="dashboard.html" class="hover:text-green-400">📋 Dashboard</a></li>
        <li class="mb-3"><a href="pending-approval.html" class="hover:text-green-400">⏳ Pending Approval</a></li>
        <li class="mb-3"><a href="pending-send.html" class="hover:text-green-400">📤 Pending to Send</a></li>
        <li class="mb-3"><a href="index.html" class="hover:text-green-400">➕ New Project</a></li>
        <li class="mb-3"><a href="contacts.html" class="hover:text-green-400">👥 Contacts</a></li>
        <li class="mb-3"><a href="stats.html" class="hover:text-green-400">📊 Stats</a></li>
        <li class="mb-3"><a href="backup.html" class="hover:text-green-400">💾 Backup</a></li>
        <li class="mb-3"><a href="technician.html" class="text-green-400 font-bold">🛠 Technician View</a></li>
      </ul>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 p-6">
      <header class="flex justify-end mb-4">
        <button id="logoutBtn" class="px-3 py-1 border rounded">Logout</button>
      </header>

      <h1 class="text-3xl font-bold mb-6">🛠 Technician Dashboard</h1>

      <!-- Uploader UI (matches /js/technician.js selectors) -->
      <section class="max-w-3xl bg-white p-4 rounded shadow">
        <h2 class="text-xl font-semibold mb-4">Upload Photos</h2>

        <label class="block mb-2">Project ID
          <input id="projectId" class="w-full border p-2 rounded" placeholder="e.g. TUR-001" required>
        </label>

        <label class="block mb-4">Task ID
          <input id="taskId" class="w-full border p-2 rounded" placeholder="e.g. TAS-001" required>
        </label>

        <div class="grid md:grid-cols-3 gap-4">
          <div class="border p-3 rounded">
            <h3 class="font-medium mb-2">Before</h3>
            <input id="beforeInput" type="file" accept="image/*" capture="environment" class="mb-2">
            <button data-type="before" class="uploadBtn bg-blue-600 text-white px-3 py-1 rounded">Upload Before</button>
          </div>

          <div class="border p-3 rounded">
            <h3 class="font-medium mb-2">After</h3>
            <input id="afterInput" type="file" accept="image/*" capture="environment" class="mb-2">
            <button data-type="after" class="uploadBtn bg-green-600 text-white px-3 py-1 rounded">Upload After</button>
          </div>

          <div class="border p-3 rounded">
            <h3 class="font-medium mb-2">Receipt</h3>
            <input id="receiptInput" type="file" accept="image/*" capture="environment" class="mb-2">
            <button data-type="receipt" class="uploadBtn bg-yellow-600 text-white px-3 py-1 rounded">Upload Receipt</button>
          </div>
        </div>

        <progress id="prog" value="0" max="100" class="w-full mt-4"></progress>
        <p id="status" class="text-sm mt-1 text-gray-600"></p>
      </section>

      <section class="max-w-5xl bg-white p-4 rounded shadow mt-6">
        <h2 class="text-xl font-semibold mb-3">Gallery</h2>
        <div id="gallery" class="grid grid-cols-2 md:grid-cols-4 gap-3"></div>
      </section>
    </main>
  </div>

  <!-- Auth + Tech uploader (single source of truth) -->
  <script type="module" src="./js/firebase-config.js"></script>
  <script type="module" src="./js/auth.js"></script>
  <script type="module" src="./js/technician.js"></script>
  <script type="module">
    import { watchAuth, logout } from "./js/auth.js";
    watchAuth(); // send guests to index.html
    document.getElementById("logoutBtn")?.addEventListener("click", logout);
  </script>
</body>
</html>
